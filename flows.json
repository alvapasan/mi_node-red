        "order": 4,
        "width": 0,
        "height": 0,
        "format": "<style>\n    /* 1. Cabecera NEGRA total */\n    .tabulator-header,\n    .tabulator-col {\n        background-color: #000000 !important;\n        color: #ffffff !important;\n        border-right: 1px solid #333 !important;\n    }\n\n    .tabulator-col-title {\n        font-size: 24px !important;\n        font-weight: 900 !important;\n        text-align: center !important;\n        width: 100% !important;\n    }\n\n    /* 2. Celdas: Centrado real sin que se muevan de columna */\n    .tabulator-cell {\n        font-size: 20px !important;\n        font-weight: bold !important;\n        text-align: center !important;\n        /* Centrado horizontal */\n        vertical-align: middle !important;\n        padding: 15px 0 !important;\n        border-right: 1px solid #eee !important;\n    }\n\n    /* 3. Columna Cantidad: Color azul y más grande */\n    .tabulator-cell[tabulator-field=\"Cantidad\"] {\n        color: #007bff !important;\n        font-size: 26px !important;\n        font-weight: 900 !important;\n    }\n\n    /* 4. Resaltar la última fila (EL TOTAL) */\n    .tabulator-row:last-child {\n        background-color: #e3f2fd !important;\n        border-top: 3px solid #000 !important;\n    }\n\n    .tabulator-row:last-child .tabulator-cell {\n        color: #000 !important;\n        font-size: 24px !important;\n    }\n\n    /* Altura de las filas */\n    .tabulator-row {\n        min-height: 65px !important;\n    }\n</style>",
