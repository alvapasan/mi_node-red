        "id": "6d568246abc9490b",
        "type": "function",
        "z": "90e51c80d7614276",
        "name": "Preparar Filtros",
        "func": "if (msg.topic === \"fecha\") {\n    let d = new Date(msg.payload);\n    flow.set(\"filtro_fecha\", d.toISOString().split('T')[0]);\n}\nif (msg.topic === \"usuario\") {\n    flow.set(\"filtro_usuario\", msg.payload);\n}\nlet f = flow.get(\"filtro_fecha\");\nlet u = flow.get(\"filtro_usuario\");\nif (f && u) {\n    msg.params = [f, u];\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 1110,
        "y": 340,
        "wires": [
            [
                "ece6cdc41778b739"
            ]
        ]
    },
