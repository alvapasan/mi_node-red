    {
        "id": "41bf10a3f79fb43e",
        "type": "function",
        "z": "90e51c80d7614276",
        "name": "Preparar Filtros",
        "func": "// 1. Guardamos en el flujo lo que acaba de llegar\nif (msg.topic === \"fecha\") {\n    let d = new Date(msg.payload);\n    let fechaFormateada = d.toISOString().split('T')[0];\n    flow.set(\"filtro_fecha\", fechaFormateada);\n}\n\nif (msg.topic === \"usuario\") {\n    flow.set(\"filtro_usuario\", msg.payload);\n}\n\n// 2. Recuperamos ambos valores\nlet f = flow.get(\"filtro_fecha\");\nlet u = flow.get(\"filtro_usuario\");\n\n// 3. Solo disparamos si tenemos ambos datos\nif (f && u) {\n    msg.params = [f, u];\n    return msg;\n} else {\n    return null; // No hace nada hasta tener los dos\n}",
        "outputs": 1,
        "x": 530,
        "y": 380,
        "wires": [
            [
                "65b961a3233f3475"
            ]
        ]
    },
