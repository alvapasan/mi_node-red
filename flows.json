    {
        "id": "f_popup",
        "type": "ui_template",
        "z": "f_login_ui",
        "group": "0ed1ee85ed6b6020",
        "name": "Popup Pass",
        "order": 2,
        "width": 1,
        "height": 1,
        "format": "<div ng-init=\"init()\" ng-show=\"showModal\">\n    <div\n        style=\"position: fixed; top: 0; left: 0; width: 100%; height: 100%; \n                background-color: rgba(15, 23, 42, 0.9); display: flex; align-items: center; justify-content: center; z-index: 9999; backdrop-filter: blur(4px);\">\n\n        <div style=\"background: #1e293b; padding: 30px; border-radius: 10px; text-align: center; width: 320px; \n                    border: 1px solid #0284c7; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);\">\n\n            <div\n                style=\"color: #ffffff; font-family: 'Segoe UI', sans-serif; font-weight: 900; font-size: 22px; margin-bottom: 5px; text-transform: uppercase;\">\n                🔐 ACCESO\n            </div>\n\n            <div\n                style=\"color: #94a3b8; font-family: 'Segoe UI', sans-serif; font-size: 11px; margin-bottom: 20px; letter-spacing: 2px; font-weight: bold;\">\n                PASSWORD REQUIRED\n            </div>\n\n            <input\n                id=\"passInput\"\n                type=\"password\"\n                ng-model=\"pass\"\n                ng-keyup=\"$event.keyCode === 13 && enviar()\"\n                style=\"width: 100%; box-sizing: border-box; padding: 12px;\n                       background-color: #0f172a; border: 1px solid #94a3b8; color: #ffffff; border-radius: 6px;\n                       outline: none; font-size: 18px; text-align: center; font-weight: bold; letter-spacing: 3px;\"\n                autocomplete=\"off\"\n            />\n\n            <br><br>\n\n            <div style=\"display: flex; justify-content: space-between; gap: 15px;\">\n                <button\n                    style=\"flex: 1; padding: 12px; background-color: #0284c7; color: #ffffff; border: none; border-radius: 6px; \n                           cursor: pointer; font-weight: bold; text-transform: uppercase; transition: 0.2s;\"\n                    onmouseover=\"this.style.backgroundColor='#0369a1'\" onmouseout=\"this.style.backgroundColor='#0284c7'\"\n                    ng-click=\"enviar()\">Entrar</button>\n\n                <button\n                    style=\"flex: 1; padding: 12px; background-color: transparent; color: #94a3b8; border: 1px solid #94a3b8; \n                           border-radius: 6px; cursor: pointer; font-weight: bold; text-transform: uppercase; transition: 0.2s;\"\n                    onmouseover=\"this.style.color='#ffffff'; this.style.borderColor='#ffffff'\" onmouseout=\"this.style.color='#94a3b8'; this.style.borderColor='#94a3b8'\"\n                    ng-click=\"cerrar()\">Salir</button>\n            </div>\n        </div>\n    </div>\n</div>\n\n<script>\n    (function(scope) {\n        scope.showModal = false;\n\n        scope.init = function() {\n            scope.$watch('msg', function(msg) {\n                if (msg && msg.payload && msg.payload.action === 'open') {\n                    scope.pass = ''; \n                    scope.showModal = true;\n                    setTimeout(() => {\n                        const input = document.getElementById('passInput');\n                        if (input) { input.focus(); }\n                    }, 150);\n                }\n            });\n        };\n\n        scope.enviar = function() {\n            scope.send({payload: scope.pass});\n            scope.showModal = false;\n        };\n\n        scope.cerrar = function() {\n            scope.showModal = false;\n        };\n    })(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": false,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
