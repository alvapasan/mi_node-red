        "z": "90e51c80d7614276",
        "name": "Mapear Dropdown Corregido",
        "func": "let lista = msg.payload;\n// 1. Añadimos la opción global al principio de la lista\nlet opciones = [\"Producción total\"]; \n\n// 2. Extraemos los usuarios de la base de datos y los añadimos después\nif (Array.isArray(lista)) {\n    for (let i = 0; i < lista.length; i++) {\n        if (lista[i].usuario) {\n            opciones.push(lista[i].usuario);\n        }\n    }\n}\n\nmsg.options = opciones;\nmsg.payload = \"\"; \nreturn msg;",
