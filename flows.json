        "id": "956e363404502256",
        "type": "function",
        "z": "90e51c80d7614276",
        "name": "Estética + Cálculo Total",
        "func": "let filas = msg.payload;\nlet sumaTotal = 0;\n\nif (Array.isArray(filas)) {\n    filas.forEach(f => {\n        sumaTotal += parseInt(f[\"Cantidad\"] || 0);\n    });\n\n    filas.push({\n        \"Tipo de Pieza\": \"TOTAL GENERAL\",\n        \"Cantidad\": sumaTotal\n    });\n}\n\nmsg.columns = [\n    {\n        \"title\": \"TIPO DE PIEZA\",\n        \"field\": \"Tipo de Pieza\",\n        \"widthGrow\": 7,\n        \"hozAlign\": \"center\",\n        \"headerHozAlign\": \"center\"\n    },\n    {\n        \"title\": \"CANTIDAD\",\n        \"field\": \"Cantidad\",\n        \"widthGrow\": 3,\n        \"hozAlign\": \"center\",\n        \"headerHozAlign\": \"center\"\n    }\n];\n\nmsg.payload = filas;\nreturn msg;",
        "outputs": 1,
        "x": 1540,
        "y": 340,
