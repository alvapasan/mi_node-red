    {
        "id": "08c75444d73b82d5",
        "type": "function",
        "z": "90e51c80d7614276",
        "name": "Preparar Datos Pie Chart",
        "func": "let filas = msg.payload;\n\n// 1. Limpiamos la gráfica anterior para que no se amontonen las búsquedas\nnode.send({ payload: [] });\n\n// 2. Mandamos las porciones de la tarta una a una\nif (Array.isArray(filas)) {\n    filas.forEach(fila => {\n        let nombre = fila[\"Tipo de Pieza\"];\n        let valor = parseInt(fila[\"Cantidad\"]);\n\n        // Filtramos para ignorar el TOTAL y valores vacíos\n        if (nombre && !nombre.includes(\"TOTAL\") && valor > 0) {\n            node.send({\n                topic: nombre,\n                payload: valor\n            });\n        }\n    });\n}\n\n// Retornamos null porque ya hemos mandado los datos con node.send()\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
