    {
        "id": "6d78a1ca3ea65fa6",
        "type": "function",
        "z": "f_login_ui",
        "name": "1. Preparar Consulta",
        "func": "// 1. Guardamos la contraseña escrita en la memoria segura del flujo\nvar passLimpia = msg.payload.toString().trim();\nflow.set(\"PassEscrita\", passLimpia);\n\n// 2. Pedimos todos los usuarios a la base de datos\nmsg.payload = {\n    query: \"SELECT * FROM usuarios_login;\"\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 440,
        "wires": [
            [
                "048ac884b6e17c82"
            ]
        ]
    },
    {
        "id": "4e43db65bcf1a28f",
        "type": "switch",
        "z": "f_login_ui",
        "name": "4. Comprobar Acceso",
        "property": "payload.length",
        "propertyType": "msg",
        "rules": [
            {
                "t": "gt",
                "v": "0",
                "vt": "num"
            },
            {
                "t": "eq",
                "v": "0",
                "vt": "num"
            }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 2,
        "x": 1140,
        "y": 440,
        "wires": [
