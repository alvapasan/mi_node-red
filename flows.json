    {
        "id": "check_pass_sql",
        "type": "function",
        "z": "f_login_ui",
        "name": "Validar en DB",
        "func": "var user = flow.get(\"selected_user\");\nvar passInput = msg.payload.pass;\n\nmsg.payload = \"SELECT * FROM usuarios_login WHERE usuario = '\" + user + \"' AND password = '\" + passInput + \"';\";\nmsg.passInput = passInput;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
